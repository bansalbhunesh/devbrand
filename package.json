{
  "name": "devbrand-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "modules/*",
    "infrastructure/*",
    "workflows/*"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "npm run dev --workspace=@devbrand/web",
    "build": "npm run build --workspace=@devbrand/web",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "prettier": "^3.7.3",
    "eslint": "^9.32.0"
  }
}
