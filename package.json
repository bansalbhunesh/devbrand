{
  "name": "devbrand-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "modules/*",
    "infrastructure/*",
    "workflows/*"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "npm run dev --workspace=@devbrand/web",
    "build": "npm run build --workspace=@devbrand/web",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "drizzle-orm": "^0.45.2",
    "eslint": "^9.32.0",
    "prettier": "^3.7.3",
    "typescript": "^5.8.3",
    "vitest": "^4.1.7",
    "ws": "^8.20.1"
  },
  "dependencies": {
    "graphql": "^16.14.0",
    "graphql-yoga": "^5.21.0"
  }
}
