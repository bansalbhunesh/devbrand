# Feature Flags
FEATURE_REPO_ROAST=true

# App URL (server OAuth, redirects, webhooks)
APP_URL=http://localhost:3000

# Public absolute origin for OG/meta in the client bundle (optional; falls back to APP_URL / devbrand.ai)
# VITE_PUBLIC_APP_URL=https://your-workers-subdomain.workers.dev

# GitHub OAuth — create at github.com/settings/applications/new
# Homepage URL: http://localhost:3000
# Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_TOKEN= # Personal Access Token for repo traversal (higher limits)

# Session Security — generate with: openssl rand -base64 32
SESSION_SECRET=

# LLM: anthropic (default) | openai_compatible (Ollama, Gemini, OpenRouter, …)
LLM_PROVIDER=anthropic

# Anthropic — console.anthropic.com (when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-3-7-sonnet-20250219

# OpenAI-compatible Chat Completions (when LLM_PROVIDER=openai_compatible)
# Base URL priority: OPENAI_COMPAT_BASE_URL → else if GEMINI_API_KEY set → Gemini host → else Ollama (OLLAMA_HOST / OPENHUMAN_OLLAMA_BASE_URL / localhost).
# Alias: GEMINI_API_KEY acts like OPENAI_COMPAT_API_KEY; GEMINI_MODEL like OPENAI_COMPAT_MODEL.
GEMINI_API_KEY=
GEMINI_MODEL=
# Optional default when using GEMINI_API_KEY without GEMINI_MODEL (see resolve.ts).
# DEFAULT_GEMINI_MODEL=gemini-2.0-flash
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=

# Local Ollama (OpenHuman-style overrides; omit when using explicit OPENAI_COMPAT_BASE_URL)
OLLAMA_HOST=
OPENHUMAN_OLLAMA_BASE_URL=

# Gemini one-liner (local .env only): LLM_PROVIDER=openai_compatible + GEMINI_API_KEY (+ optional GEMINI_MODEL)

# Postgres — neon.tech free tier
DATABASE_URL=

# Razorpay — dashboard.razorpay.com
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Upstash Redis — upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cron secret — generate with: openssl rand -base64 32
CRON_SECRET=
