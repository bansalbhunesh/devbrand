{
  "name": "devbrand-vscode",
  "displayName": "DevBrand",
  "description": "Real-time AI Engineering Judgment and Repo Roasts in your IDE",
  "version": "0.1.0",
  "publisher": "bansalbhunesh",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Linters",
    "Machine Learning"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:typescript",
    "onLanguage:javascript",
    "onLanguage:typescriptreact",
    "onLanguage:javascriptreact"
  ],
  "contributes": {
    "commands": [
      {
        "command": "devbrand.analyzeCode",
        "title": "DevBrand: Analyze Current File"
      }
    ],
    "configuration": {
      "title": "DevBrand",
      "properties": {
        "devbrand.apiKey": {
          "type": "string",
          "description": "Your DevBrand API Key for authentication"
        },
        "devbrand.autoAnalyzeOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Automatically run DevBrand analysis when saving a file"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "npm run build -- --watch",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.0.0"
  }
}
